# =============================================================================
# OpenNG — Root Environment Variables
# =============================================================================
# Copy to .env and fill in values. NEVER commit .env to git.
# For detailed per-variable docs, see apps/api/.env.example
# =============================================================================

# Database (Docker Compose defaults for local dev)
DATABASE_URL=postgresql://openng:openng_dev@localhost:5433/openng_dev

# Redis (Docker Compose defaults for local dev)
REDIS_URL=redis://localhost:6380

# Public web URL (magic link emails, CORS, redirect allowlist)
APP_URL=http://localhost:3001

# Auth secrets — generate each with: openssl rand -hex 32
SESSION_SECRET=
MAGIC_LINK_SECRET=

# Admin route bearer token — generate with: openssl rand -hex 32
ADMIN_SECRET=

# Resend.com API key (magic link emails). Get at: https://resend.com/api-keys
RESEND_API_KEY=

# Cloudflare R2 (not required for local dev)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=openng-sources

# Pino log level: debug | info | warn | error
LOG_LEVEL=debug
