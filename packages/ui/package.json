{
  "name": "@openng/ui",
  "version": "0.0.0",
  "private": true,
  "exports": {
    "./components/badge": "./src/components/badge.tsx",
    "./components/button": "./src/components/button.tsx",
    "./components/open-nav-logo": "./src/components/open-nav-logo.tsx",
    "./components/card": "./src/components/card.tsx",
    "./components/code": "./src/components/code.tsx",
    "./components/switch": "./src/components/switch.tsx",
    "./styles/globals.css": "./src/styles/globals.css"
