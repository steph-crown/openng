# =============================================================================
# OpenNG API — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to git — only this .env.example file is tracked.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# PostgreSQL connection string. For local dev, use the Docker Compose defaults:
DATABASE_URL=postgresql://openng:openng_dev@localhost:5433/openng_dev

# -----------------------------------------------------------------------------
# Cache / Rate Limiting
# -----------------------------------------------------------------------------
# Redis connection string. Docker Compose exposes Redis on port 6380 locally:
REDIS_URL=redis://localhost:6380

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
# Public-facing URL of the web app. Used for:
#   - Magic link URLs in emails (e.g. {APP_URL}/auth/verify?token=xxx)
#   - CORS origin allowlist for /auth/* and /dashboard/* routes
#   - Redirect URL validation
# Local dev uses the web app port (3001). Production: https://openng.dev
APP_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# Auth Secrets
# -----------------------------------------------------------------------------
# HMAC signing key for session cookies. Minimum 32 bytes of randomness.
# Generate: openssl rand -hex 32
SESSION_SECRET=

# HMAC key used when hashing magic link tokens. Minimum 32 bytes of randomness.
# Generate: openssl rand -hex 32
MAGIC_LINK_SECRET=

# Bearer token required for /internal/* admin routes (metrics, analytics).
# Generate: openssl rand -hex 32
ADMIN_SECRET=

# -----------------------------------------------------------------------------
# Email (Resend)
# -----------------------------------------------------------------------------
# API key from Resend (https://resend.com). Used to send magic link emails.
# Sign up → Dashboard → API Keys → Create. Free tier: 100 emails/day.
RESEND_API_KEY=

# -----------------------------------------------------------------------------
# Cloudflare R2 (Object Storage)
# -----------------------------------------------------------------------------
# Used for: raw source file archive (scraped PDFs, HTML snapshots) and backups.
# Get credentials: Cloudflare Dashboard → R2 → Manage R2 API Tokens → Create.
# Not required for local development — leave blank until scraper/backup work.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=openng-sources

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Pino log level. Options: debug, info, warn, error, fatal.
# Use "debug" locally, "info" in production.
LOG_LEVEL=debug
